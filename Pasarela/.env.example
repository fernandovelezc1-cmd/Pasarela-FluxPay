# ===========================================
# CONFIGURACIÓN WOMPI - PASARELA DE PAGOS
# ===========================================

# Puerto del servidor
PORT=3000

# Ambiente: sandbox | production
WOMPI_ENV=sandbox

# Llaves de Sandbox (Pruebas)
# Obtén tus llaves en: https://dashboard.wompi.co
WOMPI_PUBLIC_KEY_SANDBOX=tu_public_key_sandbox_aqui
WOMPI_PRIVATE_KEY_SANDBOX=tu_private_key_sandbox_aqui
WOMPI_EVENTS_SECRET_SANDBOX=tu_events_secret_sandbox_aqui
WOMPI_INTEGRITY_SECRET_SANDBOX=tu_integrity_secret_sandbox_aqui

# Llaves de Producción (Reemplazar con tus llaves reales)
WOMPI_PUBLIC_KEY_PRODUCTION=tu_public_key_production_aqui
WOMPI_PRIVATE_KEY_PRODUCTION=tu_private_key_production_aqui
WOMPI_EVENTS_SECRET_PRODUCTION=tu_events_secret_production_aqui
WOMPI_INTEGRITY_SECRET_PRODUCTION=tu_integrity_secret_production_aqui

# URL base de la aplicación
APP_URL=http://localhost:3000
